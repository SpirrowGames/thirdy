# PostgreSQL
POSTGRES_USER=thirdy
POSTGRES_PASSWORD=thirdy
POSTGRES_DB=thirdy

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Ports (override if default 8000/3000 conflict with other services)
# API_PORT=8000
# WEB_PORT=3000

# Lexora (LLM Proxy) — Docker内からホストへは http://172.17.0.1:PORT を使用
LEXORA_BASE_URL=http://localhost:8110
LEXORA_DEFAULT_MODEL=gpt-4o
CHAT_HISTORY_LIMIT=50
OUTPUT_LANGUAGE=
CHAT_SYSTEM_PROMPT=You are a helpful AI assistant.

# Specification Extraction
SPEC_EXTRACTION_SYSTEM_PROMPT=You are a specification writer. Analyze the conversation and generate a comprehensive specification document in Markdown format.

# Decision Detection
DECISION_DETECTION_SYSTEM_PROMPT=You are a decision analysis assistant. Analyze the conversation and identify ambiguities and decision points.

# Next.js (ビルド時)
NEXT_PUBLIC_API_URL=http://localhost:8000
